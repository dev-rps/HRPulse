# ─── Database ─────────────────────────────────────────────────────────────────
# Local Dev: Matches the docker-compose.yml service at localhost:5432
# Production (Vercel/Serverless): You MUST use a connection pooled database URL 
# (e.g. Neon with ?pgbouncer=true or Supabase pooled connection string on port 6543)
# to prevent database connection exhaustion during serverless invocations.
DATABASE_URL="postgresql://hrpulse:hrpulse_password@localhost:5432/hrpulse_db"

# ─── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate strong secrets in production: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change_me_in_production_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_in_production_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ────────────────────────────────────────────────────────────────────
# Port to listen on (local dev only)
PORT=4000
NODE_ENV="development"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Vite default is http://localhost:5173)
CORS_ORIGIN="http://localhost:5173"
