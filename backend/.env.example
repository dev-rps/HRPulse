# ─── Database ─────────────────────────────────────────────────────────────────
# Matches the docker-compose.yml service at localhost:5432
DATABASE_URL="postgresql://hrpulse:hrpulse_password@localhost:5432/hrpulse_db"

# ─── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate strong secrets in production: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change_me_in_production_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_in_production_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (frontend dev server)
CORS_ORIGIN="http://localhost:3000"
